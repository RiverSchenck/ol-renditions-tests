# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/

# Production / generic build output
/build
/dist

# Testing
/coverage
*.lcov
.nyc_output

# Vercel
.vercel

# Environment (keep examples tracked)
.env*
!.env.example
!.env*.example

# Debug & package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# TypeScript
*.tsbuildinfo
next-env.d.ts

# TLS / keys
*.pem

# Caches
.eslintcache
.prettiercache
.turbo

# Playwright / e2e (if you add them later)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors (uncomment if you never commit IDE settings)
# .vscode/
.idea/
*.swp
*.swo
*~
