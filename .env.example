# Copy to `.env` and replace every value with your real brand credentials.
# Examples below show typical shape only — they will not work as-is.

# Full GraphQL endpoint for your Frontify brand (required).
FRONTIFY_GRAPHQL_URL=https://your-brand.frontify.com/graphql

# Personal access token or OAuth bearer — sent as Authorization: Bearer <token>
# (Also used when downloading previewUrl for JPEG white-border checks, if required.)
FRONTIFY_ACCESS_TOKEN=f1a2b3c4-d5e6-7890-abcd-ef1234567890

# Library id to query (required): positive integer, digits only (e.g. 23).
FRONTIFY_LIBRARY_ID=23
